[package]
name = "ntag424"
version = "0.1.0-beta1"
keywords = ["nfc", "ntag424"]
categories = ["embedded", "cryptography", "no-std"]
authors = ["Jannik Schürg <jannik.schuerg+crates@posteo.de>"]
description = "Implementation of the application protocol of NTAG 424 DNA chips."
license = "MIT OR Apache-2.0"
readme = "../README.md"
repository = "https://codeberg.org/jannschu/ntag424"
edition = "2024"
rust-version = "1.88.0"

[features]
default = ["alloc"]
alloc = []
key_diversification = []
sdm = []
serde = ["dep:serde"]

[dependencies]
aes = "0.9.0"
serde = { version = "1", default-features = false, features = [
  "derive",
], optional = true }
arrayvec = { version = "0.7", default-features = false }
cmac = "0.8.0"
p224 = { version = "0.13.2", default-features = false, features = ["ecdsa"] }
subtle = { version = "2", default-features = false }
thiserror = { version = "2.0.18", default-features = false }

[package.metadata.docs.rs]
all-features = true
rustdoc-args = ["--cfg", "docsrs"]
